# Environment Configuration
# Copy this to .env and fill in your values

# Google Earth Engine
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

# Data Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
OUTPUT_DIR=outputs
LOG_DIR=logs

# Processing Configuration
N_WORKERS=4
CHUNK_SIZE=10
VERBOSE=true

# Water Detection
WATER_VV_THRESHOLD=-12.0
WATER_VH_VV_RATIO=0.25
CONFIDENCE_MIN=0.5

# Scenario Configuration
SCENARIO_ENABLED_1=true
SCENARIO_ENABLED_2=true
SCENARIO_ENABLED_3=true
SCENARIO_ENABLED_4=true

# Validation
GENERATE_ACCURACY_REPORTS=true
MANUAL_VALIDATION=false
VALIDATION_DATA_PATH=null

# Email Alerts (Optional)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=your-email@example.com
ALERT_EMAIL_FROM=system@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
